PROJECT_NAME="Legal AI Gateway"
DATABASE_URL=postgresql://postgres:postgres@db:5432/legal_ai
REDIS_URL=redis://redis:6379/0
# OLLAMA_URL=http://host.docker.internal:11434/api/generate
# OLLAMA_MODEL=llama3.2
JWT_SECRET_KEY=supersecretkeyforaccesstokenrefactoring123!
JWT_REFRESH_SECRET_KEY=supersecretkeyforrefreshtokenrefactoring123!
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Gemini Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
EMBEDDING_MODEL=text-embedding-004
GEMINI_TEMPERATURE=0.2
GEMINI_MAX_OUTPUT_TOKENS=2048

# RAG Configuration
CHUNK_SIZE=500
CHUNK_OVERLAP=100
RETRIEVAL_LIMIT=5
SIMILARITY_THRESHOLD=0.5